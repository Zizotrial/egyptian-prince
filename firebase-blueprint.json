{
  "entities": {
    "Score": {
      "title": "Score",
      "description": "A player's high score entry",
      "type": "object",
      "properties": {
        "playerName": {
          "type": "string",
          "description": "The name of the player"
        },
        "score": {
          "type": "integer",
          "description": "The score achieved"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "When the score was achieved"
        },
        "userId": {
          "type": "string",
          "description": "The Firebase Auth UID of the player"
        }
      },
      "required": ["playerName", "score", "timestamp", "userId"]
    }
  },
  "firestore": {
    "/scores/{scoreId}": {
      "schema": "Score",
      "description": "Global leaderboard scores"
    }
  }
}
