rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: scores
    // Document ID: auto-generated
    // Fields:
    //   - playerName: string (required, 1-20 chars)
    //   - score: number (required, positive)
    //   - timestamp: timestamp (required)
    //   - userId: string (required, matches auth.uid)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "elkhashab@google.com" && request.auth.token.email_verified == true));
    }

    function isValidScore(data) {
      return data.playerName is string && 
             data.playerName.size() >= 1 && 
             data.playerName.size() <= 20 &&
             data.score is number && 
             data.score >= 0 &&
             data.timestamp is timestamp &&
             data.userId == request.auth.uid;
    }

    match /scores/{scoreId} {
      // Allow anyone to read the top scores
      allow read: if true;
      
      // Allow authenticated users to create their own scores
      allow create: if isAuthenticated() && isValidScore(request.resource.data);
      
      // Scores are immutable once created
      allow update, delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }
  }
}
